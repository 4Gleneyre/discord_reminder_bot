{
  "name": "discord-reminder-bot",
  "version": "0.1.0",
  "description": "A personal Discord reminder bot with timezone-aware slash commands.",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "register": "node src/register-commands.js",
    "deploy:worker": "wrangler deploy",
    "d1:migrate": "wrangler d1 migrations apply discord-reminder-bot-db --remote",
    "test": "node --test"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "discord-interactions": "^4.4.0",
    "discord.js": "^14.19.3",
    "dotenv": "^16.5.0",
    "luxon": "^3.6.1"
  },
  "devDependencies": {
    "wrangler": "^4.100.0"
  }
}
